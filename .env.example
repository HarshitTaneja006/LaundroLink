# LaundroLink Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# ============================================================================
# REQUIRED: Database Configuration
# ============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/laundrolink

# ============================================================================
# REQUIRED: Session Security
# ============================================================================
# Session secret key (MUST be set, no defaults)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-long-random-secret-here-at-least-32-characters

# ============================================================================
# REQUIRED: AI Matching Service
# ============================================================================
# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================================
# Application Configuration
# ============================================================================
# Environment: development | production
NODE_ENV=development

# Server port
PORT=5000

# ============================================================================
# Optional: Advanced Configuration
# ============================================================================
# Enable verbose logging
DEBUG=laundrolink:*

# Maximum file upload size (bytes)
MAX_UPLOAD_SIZE=5242880

# Session timeout (milliseconds)
# Default: 24 hours = 86400000
SESSION_TIMEOUT=86400000

# ============================================================================
# SECURITY NOTES
# ============================================================================
# 1. SESSION_SECRET MUST be long, random, and unique
#    - Never use the default
#    - Generate: openssl rand -hex 32
#    - Store securely, never commit to git
#
# 2. GEMINI_API_KEY must be kept confidential
#    - Never share in code, logs, or error messages
#    - Rotate if exposed
#    - Use restricted API keys in production
#
# 3. DATABASE_URL
#    - Use strong passwords in production
#    - Enable SSL/TLS for database connections
#    - Restrict database access to application only
#
# 4. Production Deployment
#    - Always set NODE_ENV=production
#    - Use environment variables, not files
#    - Enable HTTPS
#    - Run security audit before deploying
#
# ============================================================================
